{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.dotfiles/bin/claude-hook-open-md-preview",
            "statusMessage": "Opening in Markdown editor...",
            "async": true
          }
        ]
      }
    ]
  }
}
